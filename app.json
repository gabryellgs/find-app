{
  "expo": {
    "name": "front-find",
    "slug": "front-find",
    "scheme": "findapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo-find.webp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo/logo-find.webp",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo-find.webp",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Find usa sua localização para marcar onde um item foi encontrado ou perdido."
        }
      ]
    ]
  }
}
